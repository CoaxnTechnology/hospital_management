msgstr "Yes, delete!"

msgid "Non, annuler"
msgstr "No, cancel"

msgid "Oui, annuler l'admission!"
msgstr "Yes, cancel the admission!"

msgid "Non, conserver l'admission"
msgstr "No, keep the admission"

msgid "Oui, supprimer le praticien!"
msgstr "Yes, remove the practitioner!"

msgid "Non, conserver le praticien"
msgstr "No, keep the practitioner"

